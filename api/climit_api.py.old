import os
from flask import Flask, jsonify, request
import psycopg2
import psycopg2.extras
from datetime import datetime
from flask_cors import CORS

DB_HOST = os.getenv("DB_HOST", "postgres")
DB_NAME = os.getenv("DB_NAME", "climitdb")
DB_USER = os.getenv("DB_USER", "climit")
DB_PASS = os.getenv("DB_PASS", "climit")

app = Flask(__name__)
CORS(app)

def get_conn():
    return psycopg2.connect(
        host=DB_HOST,
        dbname=DB_NAME,
        user=DB_USER,
        password=DB_PASS,
    )


@app.route("/api/health")
def health():
    return {"status": "ok"}


@app.route("/api/sensors", methods=["GET"])
def list_sensors():
    conn = get_conn()
    cur = conn.cursor(cursor_factory=psycopg2.extras.DictCursor)
    cur.execute("""
        SELECT id, site_id, name, type, serial_number
        FROM sensors
        ORDER BY id
    """)
    rows = cur.fetchall()
    cur.close()
    conn.close()
    return jsonify([dict(r) for r in rows])


@app.route("/api/measurements", methods=["GET"])
def list_measurements():
    sensor_id = request.args.get("sensor_id", type=int)
    limit = request.args.get("limit", default=100, type=int)
    from_ts = request.args.get("from")
    to_ts = request.args.get("to")

    conn = get_conn()
    cur = conn.cursor(cursor_factory=psycopg2.extras.DictCursor)

    sql = """
        SELECT id, sensor_id, measured_at, value_celsius
        FROM measurements
    """
    clauses = []
    params = []

    if sensor_id is not None:
        clauses.append("sensor_id = %s")
        params.append(sensor_id)
    if from_ts is not None:
        clauses.append("measured_at >= %s")
        params.append(from_ts)
    if to_ts is not None:
        clauses.append("measured_at <= %s")
        params.append(to_ts)

    if clauses:
        sql += " WHERE " + " AND ".join(clauses)

    sql += " ORDER BY measured_at DESC LIMIT %s"
    params.append(limit)

    cur.execute(sql, params)
    rows = cur.fetchall()
    cur.close()
    conn.close()

    # cast Decimal -> float, datetime -> isoformat
    result = []
    for r in rows:
        d = dict(r)
        d["value_celsius"] = float(d["value_celsius"])
        d["measured_at"] = d["measured_at"].isoformat()
        result.append(d)

    return jsonify(result)


@app.route("/api/measurements/latest", methods=["GET"])
def latest_per_sensor():
    conn = get_conn()
    cur = conn.cursor(cursor_factory=psycopg2.extras.DictCursor)
    cur.execute("""
        SELECT DISTINCT ON (sensor_id)
               id, sensor_id, measured_at, value_celsius
        FROM measurements
        ORDER BY sensor_id, measured_at DESC
    """)
    rows = cur.fetchall()
    cur.close()
    conn.close()

    result = []
    for r in rows:
        d = dict(r)
        d["value_celsius"] = float(d["value_celsius"])
        d["measured_at"] = d["measured_at"].isoformat()
        result.append(d)

    return jsonify(result)


if __name__ == "__main__":
    app.run(host="0.0.0.0", port=5000)
